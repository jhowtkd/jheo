# Uncomment and adjust to override defaults.
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# API_PORT=8080
# JHEO_SECRET_KEY=

# --- LLM provider routing (F2 generation + F7 suggestion) ---
# Route the OpenAIProvider (completion) through an OpenAI-compatible host
# (e.g. MiniMax). The provider appends `/v1/chat/completions`, so supply
# scheme+host only. Leave unset to use the real OpenAI endpoint.
# OPENAI_BASE_URL=https://api.openai.com

# When OPENAI_BASE_URL is set to a third-party host, OPENAI_API_KEY is the
# key for that host. Embeddings (used by F2 generation) keep going to real
# OpenAI via the `openai_embedding_api_key` Setting row, or via the
# `OPENAI_EMBEDDING_API_KEY` env below.
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_API_KEY=sk-proj-...

# F7 Suggestion + F6 translate model name. Default in source is
# `gpt-4o-mini`, which works on real OpenAI but is rejected by MiniMax-style
# hosts. Set this to the deployment name the host expects (e.g. `MiniMax-M3`).
# Translate also reads `JHEO_TRANSLATE_MODEL` if you need a different model
# for i18n than for suggestions; otherwise it falls back to this value.
# JHEO_SUGGESTION_MODEL=MiniMax-M3
# JHEO_TRANSLATE_MODEL=MiniMax-M3