{
  "name": "@jheo/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./reports": {
      "types": "./dist/reports/index.d.ts",
      "import": "./dist/reports/index.js"
    },
    "./reports/charts": {
      "types": "./dist/reports/charts.d.ts",
      "import": "./dist/reports/charts.js"
    },
    "./i18n/locale": {
      "types": "./dist/i18n/locale.d.ts",
      "import": "./dist/i18n/locale.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "jsonpath-plus": "10.2.0",
    "yaml": "2.5.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "typescript": "5.6.2",
    "vitest": "2.0.5"
  }
}
