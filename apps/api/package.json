{
  "name": "@jheo/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check \"src/**/*.{ts,tsx}\"",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@jheo/core": "workspace:*",
    "@fastify/cors": "9.0.1",
    "@prisma/client": "5.18.0",
    "bullmq": "5.12.0",
    "fastify": "4.28.1",
    "ioredis": "5.4.1",
    "pg": "8.12.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/pg": "8.11.6",
    "dotenv": "16.4.5",
    "prisma": "5.18.0",
    "tsx": "4.16.2",
    "typescript": "5.6.2",
    "vitest": "2.0.5"
  }
}